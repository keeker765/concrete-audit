# ===== Patch consistency helpers (top-level) =====
def extract_patch(img_gray, x, y, radius=10):
    h, w = img_gray.shape[:2]
    x = int(round(float(x)))
    y = int(round(float(y)))
    x1, y1 = x - radius, y - radius
    x2, y2 = x + radius + 1, y + radius + 1
    if x1 < 0 or y1 < 0 or x2 > w or y2 > h:
        return None
    patch = img_gray[y1:y2, x1:x2]
    return patch if patch.size else None


def patch_ncc(p1, p2):
    if p1 is None or p2 is None or p1.shape != p2.shape:
        return None
    a = p1.astype(np.float32)
    b = p2.astype(np.float32)
    a = a - a.mean()
    b = b - b.mean()
    da = np.sqrt((a * a).sum())
    db = np.sqrt((b * b).sum())
    if da < 1e-6 or db < 1e-6:
        return None
    return float((a * b).sum() / (da * db))


def compute_patch_consistency(rectified1, rectified2, match_overlay_data, patch_radius=10):
    if match_overlay_data is None:
        return {
            'patch_ncc_mean': 0.5,
            'patch_ncc_median': 0.5,
            'patch_ssim_mean': 0.5,
            'patch_valid_ratio': 0.0,
        }
    pts0 = match_overlay_data.get('pts0')
    pts1 = match_overlay_data.get('pts1')
    inliers_mask = match_overlay_data.get('inliers_mask')
    if pts0 is None or pts1 is None or len(pts0) == 0 or len(pts1) == 0:
        return {
            'patch_ncc_mean': 0.5,
            'patch_ncc_median': 0.5,
            'patch_ssim_mean': 0.5,
            'patch_valid_ratio': 0.0,
        }

    gray0 = cv2.cvtColor(rectified1, cv2.COLOR_BGR2GRAY)
    gray1 = cv2.cvtColor(rectified2, cv2.COLOR_BGR2GRAY)
    ncc_vals = []
    ssim_vals = []
    valid = 0
    total = 0

    for i, (p0, p1) in enumerate(zip(pts0, pts1)):
        if inliers_mask is not None and len(inliers_mask) > i and not bool(inliers_mask[i]):
            continue
        total += 1
        pa = extract_patch(gray0, p0[0], p0[1], radius=patch_radius)
        pb = extract_patch(gray1, p1[0], p1[1], radius=patch_radius)
        if pa is None or pb is None:
            continue
        valid += 1
        ncc = patch_ncc(pa, pb)
        if ncc is not None:
            ncc_vals.append((ncc + 1.0) / 2.0)
        try:
            ssim_val = compute_ssim_fast(cv2.cvtColor(pa, cv2.COLOR_GRAY2BGR), cv2.cvtColor(pb, cv2.COLOR_GRAY2BGR))
            ssim_vals.append(float(ssim_val))
        except Exception:
            pass

    if not ncc_vals:
        return {
            'patch_ncc_mean': 0.5,
            'patch_ncc_median': 0.5,
            'patch_ssim_mean': float(np.mean(ssim_vals)) if ssim_vals else 0.5,
            'patch_valid_ratio': (valid / total) if total else 0.0,
        }

    return {
        'patch_ncc_mean': float(np.mean(ncc_vals)),
        'patch_ncc_median': float(np.median(ncc_vals)),
        'patch_ssim_mean': float(np.mean(ssim_vals)) if ssim_vals else float(np.mean(ncc_vals)),
        'patch_valid_ratio': (valid / total) if total else 0.0,
    }

