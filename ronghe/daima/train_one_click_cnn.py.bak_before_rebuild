            'patch_ncc_mean', 'patch_ncc_median', 'patch_ssim_mean', 'patch_valid_ratio', 'pair_dir'
        ])
        writer.writeheader()
        for row in summary_rows:
            writer.writerow(row)

    print('')
    print(f'批量处理完成，结果目录: {run_dir}')
